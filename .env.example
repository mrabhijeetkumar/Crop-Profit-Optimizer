# Backend
APP_ENV=production
PORT=5001
SECRET_KEY=replace-with-a-strong-secret
LOG_LEVEL=INFO
MODEL_PATH=models/crop_model.pkl

# API Keys (optional but recommended)
MANDI_API_KEY=your_data_gov_api_key
WEATHER_API_KEY=your_openweather_api_key
OPENAI_API_KEY=
GEMINI_API_KEY=

# CORS (comma-separated)
CORS_ORIGINS=https://your-netlify-site.netlify.app,http://localhost:8888

# Frontend runtime (static site): keep empty to use Netlify proxy routes,
# or set a direct backend origin in frontend/static/js/config.js.
# API_BASE_URL=
